# Non-public design docs and scratch
/doc/wip/
/.prompt/
/.idea/

# Compiled crofty binary
/crofty

# Dogfood site instance (user content + deploy config; lives here only as a
# working copy for now, not part of the public product)
/site/

# Build output and per-project tool state (in case a project lives in-repo)
/dist/
/.crofty/

# Wrangler local cache (created when deploy shells out)
/.wrangler/

# demo/ is a tracked example crofty project — keep its source (content, hugo.yaml,
# AGENTS.md), ignore build output and per-deploy tool state (.crofty holds the
# pinned account id, which is deployment-specific, not part of the example).
/demo/dist/
/demo/.crofty/
/demo/.wrangler/
/demo/.hugo_build.lock
