# Non-public design docs and scratch
/doc/wip/
/.prompt/
/.idea/

# Compiled crofty binary
/crofty

# Dogfood site instance (user content + deploy config; lives here only as a
# working copy for now, not part of the public product)
/site/

# Build output and per-project tool state (in case a project lives in-repo)
/dist/
/.crofty/

# wharfy's generated release config and build artifacts (regenerated each run)
/.wharfy/

# Wrangler local cache (created when deploy shells out)
/.wrangler/

# examples/ holds focused single-purpose crofty sites (blog, portfolio, shop, …)
# that showcase the breadth of sites crofty builds. Keep the source, ignore build
# output and per-deploy tool state (.crofty holds the deploy-specific account id).
/examples/*/dist/
/examples/*/public/
/examples/*/.crofty/
/examples/*/.wrangler/
/examples/*/.hugo_build.lock
